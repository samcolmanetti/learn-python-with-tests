{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "steps": {
    "install": {
      "commands": ["npm install"]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": ["npx honkit build book ../_book"]
    }
  },
  "deploy": {
    "startCommand": "npx serve _book --listen 3000 --no-clipboard"
  }
}
